{
  "build": {
    "env": {
      "PYTHONUNBUFFERED": "1",
      "DJANGO_SETTINGS_MODULE": "backend.settings",
      "PYTHONPATH": "backend"
    },
    "buildCommand": "pip install -r backend/requirements.txt",
    "startCommand": "python backend/manage.py migrate && python backend/manage.py collectstatic --noinput && gunicorn backend.wsgi:application"
  },
  "deploy": {
    "branch": "main",
    "rootDirectory": "backend",
    "healthcheckPath": "/",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
